# Common variable for common system technique
bundle common system_common {
  vars:
    "directiveId"           string => "hasPolicyServer-root@@common-hasPolicyServer-root@@0";
    "sharedfiles_folder"    string => "${g.shared_files}";
    "cf_serverd_port"       string => "5309";
    "community_port"        string => "${server_info.policy_server_port}";
    "uuid"                  string => "c8813416-316f-4307-9b6a-ca9c109a9fb0";
    "davuser"               string => "rudder";
    "davpw"                 string => "rudder";
    "rudder_configuration_repository"
                            string => "/tmp/test-rudder-config-repo-2026-06-04T22:09:53.164+02:00/configuration-repository";
    "rudder_node_config_id" string => "cfe-node-cfg-id";
    "agent_run_interval"    string => "5";
    "schedule_events"       string => '{
  "events" : [
    {
      "schedule" : "once",
      "id" : "test-schedule-1",
      "scheduleId" : "test-schedule",
      "name" : "A daily test schedule for benchmarks",
      "type" : "benchmarks",
      "notBefore" : "2026-02-15T15:05:54Z",
      "notAfter" : "2026-02-15T16:26:42Z"
    }
  ]
}';

    "cf_serverd_service_name" string => "rudder-cf-serverd";

    system_common_pass3.executor::
      "inventory_splay_hex" string => string_head(hash("${sys.host}", "md5"), "7");
      # first line is the data used to create splay hash
      # +0 is the uid of the user we use to run (root)
      # Other lines are used to compute real splay time
      "executor_data"       string => execresult("printf '${sys.fqhost}+${sys.ipv4}+0\n${sys.systime}\n4\n${agent_run_interval}\n${inventory_splay_hex}\n' > /var/rudder/tmp/cf-execd.data ", "useshell");

  classes:
    "system_common_pass3" expression => "system_common_pass2";
    "system_common_pass2" expression => "any";

}
