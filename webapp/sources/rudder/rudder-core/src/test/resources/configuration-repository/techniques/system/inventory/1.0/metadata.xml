
<TECHNIQUE name="Make an inventory of the node">
  <DESCRIPTION>Inventory of the computer</DESCRIPTION>

  <POLICY_TYPES>rudder.system,post-action</POLICY_TYPES>

  <MULTIINSTANCE>false</MULTIINSTANCE>

  <SYSTEMVARS>
    <NAME>AGENT_RUN_INTERVAL</NAME>
  </SYSTEMVARS>

  <BUNDLES>
    <NAME>doInventory</NAME>
  </BUNDLES>

  <TMLS>
    <TML name="fusionAgent"/>
    <TML name="test-inventory.pl">
      <OUTPATH>inventory/1.0/test-inventory.pl</OUTPATH>
      <INCLUDED>false</INCLUDED>
    </TML>
  </TMLS>

  <SECTIONS>
    <SECTION name="Inventory" component="true">
      <REPORTKEYS>
            <VALUE>None</VALUE>
      </REPORTKEYS>
    </SECTION>
  </SECTIONS>

</TECHNIQUE>
