def version = "9.2"
def slackResponse = null

def errors = []

def changeUrl = env.CHANGE_URL

// Check vulns in dependencies on repo branches
def failedBuild = false

pipeline {
    agent none

    environment {
        CI = 1
    }
    triggers { cron('@daily') }

    stages {
        stage('deps') {
            when { not { changeRequest() } }
            agent {
                dockerfile {
                    label 'generic-docker'
                    filename 'webapp/sources/Dockerfile'
                    // and share maven cache
                    args '-u 0:0 -v /srv/cache/maven:/root/.m2'
                }
            }
            environment {
                TRIVY_DISABLE_VEX_NOTICE = '1'
            }
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    dir('webapp/sources/') {
                        sh script: 'mvn --batch-mode -Djansi.passthrough=true -Dstyle.color=always dependency:resolve', label: "load webapp dependencies"
                    }
                    dir('webapp/sources/rudder/rudder-web/src/main/') {
                        sh script: "npm_config_loglevel=error npm ci --no-audit", label: "load npm dependencies"
                    }
                    sh script: "trivy fs --no-progress .", label: "scanning dependencies for vulnerabilities"
                }
            }
            post {
                failure {
                    script {
                        errors.add("deps")
                        failedBuild = true
                        slackResponse = updateSlack(errors, slackResponse, version, changeUrl, false)
                        slackSend(channel: slackResponse.threadId, message: "Dependency check error - <${currentBuild.absoluteUrl}console|Console>", color: "#CC3421")
                    }
                }
            }
        }
        stage('deps-rust-pr') {
            when { changeRequest() }
            agent {
                dockerfile {
                    label 'generic-docker'
                    filename 'relay/sources/relayd/Dockerfile'
                    // mount cache
                    args '-u 0:0 -v /srv/cache/cargo:/usr/local/cargo/registry'
                }
            }
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh script: 'mkdir -p target', label: 'create target directory'
                    sh script: 'cargo deny check licenses sources bans', label: 'check rust dependencies'
                }
            }
            post {
                failure {
                    script {
                        errors.add("rust")
                        failedBuild = true
                        slackResponse = updateSlack(errors, slackResponse, version, changeUrl, false)
                        slackSend(channel: slackResponse.threadId, message: "Dependency check error on rust projects - <${currentBuild.absoluteUrl}console|Console>", color: "#CC3421")
                    }
                }
            }
        }
        stage('End') {
            steps {
                script {
                    updateSlack(errors, slackResponse, version, changeUrl, true)
                    if (failedBuild) {
                        error 'End of build'
                    } else {
                        echo 'End of build '
                    }
                }
            }
        }
    }
}

def updateSlack(errors, slackResponse, version, changeUrl, isEnded) {
  def msg ="*${version} - rudder dependency check* - <"+currentBuild.absoluteUrl+"|Link>"

  if (changeUrl == null) {

      def fixed = currentBuild.resultIsBetterOrEqualTo("SUCCESS") && currentBuild.previousBuild.resultIsWorseOrEqualTo("UNSTABLE")
      if (errors.isEmpty() && isEnded && fixed) {
        msg +=  " => No security issues found! :white_check_mark:"
        def color = "good"
        slackSend(channel: "ci-security", message: msg, color: color)
      }


      if (! errors.isEmpty()) {
          msg += "\n*Errors* :x: ("+errors.size()+")\n  • " + errors.join("\n  • ")
          def color = "#CC3421"
          if (slackResponse == null) {
            slackResponse = slackSend(channel: "ci-security", message: msg, color: color)
          }
          slackSend(channel: slackResponse.channelId, message: msg, timestamp: slackResponse.ts, color: color)
      }
      return slackResponse
  }
}
